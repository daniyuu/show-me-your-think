# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Scopes needed: repo (for private repos) or public_repo
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: Custom Anthropic API base URL
# Use this to point to a local proxy or custom endpoint
# Default: https://api.anthropic.com (uses official API)
# Example: http://localhost:4141
ANTHROPIC_BASE_URL=http://localhost:4141

# Optional: Model to use for analysis
# Default: claude-opus-4.6
# Other options: claude-sonnet-4-20250514, etc.
MODEL=claude-opus-4.6
