# GitHub OAuth App credentials
# Create OAuth App at: https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback (for development)
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# Optional: For development/testing without OAuth
# GitHub Personal Access Token (fallback)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# Anthropic API Key (can be dummy for local proxy)
ANTHROPIC_API_KEY=dummy-key

# Custom Anthropic API base URL - using local proxy
ANTHROPIC_BASE_URL=http://localhost:4141

# Model to use for analysis
# Default: claude-opus-4.6
# Other options: claude-sonnet-4-20250514, etc.
MODEL=claude-opus-4.6

# Optional: Base URL for OAuth callbacks
# NEXTAUTH_URL=http://localhost:3000
